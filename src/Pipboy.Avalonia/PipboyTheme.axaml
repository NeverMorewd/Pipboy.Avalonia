<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Pipboy.Avalonia.PipboyTheme">
    <!--
        All control styles are resolved at compile time through this StyleInclude chain,
        making them NativeAOT-safe (no runtime URI lookup required).
    -->
    <StyleInclude Source="avares://Pipboy.Avalonia/Styles/PipboyTheme.axaml" />
</Styles>
