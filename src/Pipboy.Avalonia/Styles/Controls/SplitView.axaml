<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>

        <ControlTheme x:Key="{x:Type SplitView}" TargetType="SplitView">
            <Setter Property="Background" Value="{DynamicResource PipboyBackgroundBrush}" />
            <Setter Property="PaneBackground" Value="{DynamicResource PipboySurfaceBrush}" />
            <Setter Property="OpenPaneLength" Value="220" />
            <Setter Property="Template">
                <ControlTemplate TargetType="SplitView">
                    <Grid>
                        <!--  Main content  -->
                        <Grid Name="PART_ContentRoot" Background="{TemplateBinding Background}">
                            <ContentPresenter
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Content="{TemplateBinding Content}" />
                        </Grid>
                        <!--  Side pane overlay (for compact/overlay display modes)  -->
                        <Grid
                            Name="PART_PaneRoot"
                            HorizontalAlignment="Left"
                            Background="{TemplateBinding PaneBackground}">
                            <Border BorderBrush="{DynamicResource PipboyBorderBrush}" BorderThickness="0,0,1,0">
                                <ContentPresenter
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Content="{TemplateBinding Pane}" />
                            </Border>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

    </Styles.Resources>
</Styles>
