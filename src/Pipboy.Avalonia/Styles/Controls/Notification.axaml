<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:notifications="using:Avalonia.Controls.Notifications">
    <Styles.Resources>

        <!--
            ═══════════════════════════════════════════════════════════════════════
            WindowNotificationManager
            ═══════════════════════════════════════════════════════════════════════
        -->
        <ControlTheme x:Key="{x:Type notifications:WindowNotificationManager}" TargetType="notifications:WindowNotificationManager">
            <Setter Property="Template">
                <ControlTemplate TargetType="notifications:WindowNotificationManager">
                    <StackPanel Name="PART_Items" Margin="16" />
                </ControlTemplate>
            </Setter>

            <Style Selector="^:topleft /template/ StackPanel#PART_Items">
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>
            <Style Selector="^:topright /template/ StackPanel#PART_Items">
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
            <Style Selector="^:topcenter /template/ StackPanel#PART_Items">
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
            <Style Selector="^:bottomleft /template/ StackPanel#PART_Items">
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>
            <Style Selector="^:bottomright /template/ StackPanel#PART_Items">
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
            <Style Selector="^:bottomcenter /template/ StackPanel#PART_Items">
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>
        </ControlTheme>

        <!--
            ═══════════════════════════════════════════════════════════════════════
            NotificationCard
            All types share the same border/background color.
            Level is distinguished by a Path icon whose Data changes per pseudo-class.
            
            Icon path data (24×24 viewport, stroke-only, Pipboy wireframe style):
            :information  — circle with "i" (dot + bar)
            :success      — bold checkmark
            :warning      — triangle with "!" (bar + dot)
            :error        — X cross
            ═══════════════════════════════════════════════════════════════════════
        -->
        <ControlTheme x:Key="{x:Type notifications:NotificationCard}" TargetType="notifications:NotificationCard">
            <Setter Property="Background" Value="{DynamicResource PipboySurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PipboyTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PipboyBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="320" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <ControlTemplate TargetType="notifications:NotificationCard">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <Border.DataTemplates>
                            <DataTemplate DataType="INotification">
                                <StackPanel Spacing="3">
                                    <TextBlock
                                        FontWeight="Bold"
                                        Text="{Binding Title}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="{DynamicResource PipboyTextDimBrush}"
                                        Text="{Binding Message}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </Border.DataTemplates>

                        <DockPanel>
                            <!--  Left accent bar (fixed primary color, same for all types)  -->
                            <Border
                                Width="3"
                                Background="{DynamicResource PipboyBorderBrush}"
                                DockPanel.Dock="Left" />

                            <!--  Icon + content + close  -->
                            <DockPanel Margin="10,10,10,10">
                                <Button
                                    Margin="6,0,0,0"
                                    Padding="4,1"
                                    VerticalAlignment="Top"
                                    notifications:NotificationCard.CloseOnClick="True"
                                    Content="✕"
                                    DockPanel.Dock="Right" />

                                <!--  Level icon — default data = information, overridden by pseudo-class  -->
                                <Path
                                    Name="PART_Icon"
                                    Width="16"
                                    Height="16"
                                    Margin="0,2,10,0"
                                    VerticalAlignment="Top"
                                    Data="{DynamicResource PipboyIconInformation}"
                                    DockPanel.Dock="Left"
                                    Fill="Transparent"
                                    Stretch="Uniform"
                                    Stroke="{TemplateBinding Foreground}"
                                    StrokeJoin="Miter"
                                    StrokeLineCap="Square"
                                    StrokeThickness="{DynamicResource PipboyIconStrokeThickness}" />

                                <ContentPresenter VerticalAlignment="Top" Content="{TemplateBinding Content}" />
                            </DockPanel>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter>

            <!--  Closing: fade out, then set IsClosed=True so WNM removes the card  -->
            <Style Selector="^[IsClosing=true]">
                <Style.Animations>
                    <Animation FillMode="Forward" Duration="0:0:0.25">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="1" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="0" />
                            <Setter Property="IsClosed" Value="True" />
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>

            <!--  :information — circle with "i" (dot above, vertical bar below)  -->
            <Style Selector="^:information /template/ Path#PART_Icon">
                <Setter Property="Data" Value="{DynamicResource PipboyIconInformation}" />
            </Style>

            <!--  :success — checkmark  -->
            <Style Selector="^:success /template/ Path#PART_Icon">
                <Setter Property="Data" Value="{DynamicResource PipboyIconSuccess}" />
            </Style>

            <!--  :warning — triangle with exclamation (bar + dot)  -->
            <Style Selector="^:warning /template/ Path#PART_Icon">
                <Setter Property="Data" Value="{DynamicResource PipboyIconWarning}" />
            </Style>

            <!--  :error — X cross  -->
            <Style Selector="^:error /template/ Path#PART_Icon">
                <Setter Property="Data" Value="{DynamicResource PipboyIconError}" />
            </Style>

        </ControlTheme>

    </Styles.Resources>
</Styles>
