<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia">
    <Styles.Resources>

        <ControlTheme x:Key="{x:Type pipboy:SegmentedBar}" TargetType="pipboy:SegmentedBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <ControlTemplate TargetType="pipboy:SegmentedBar">
                    <StackPanel Spacing="3">

                        <!--  Optional label + value/maximum row  -->
                        <Grid
                            ColumnDefinitions="*,Auto"
                            IsVisible="{TemplateBinding Label,
                                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock
                                Grid.Column="0"
                                Foreground="{DynamicResource PipboyTextDimBrush}"
                                Text="{TemplateBinding Label}" />
                            <TextBlock Grid.Column="1" Foreground="{DynamicResource PipboyTextBrush}">
                                <Run Text="{TemplateBinding DisplayValue}" />
                                <Run Foreground="{DynamicResource PipboyTextDimBrush}" Text="/" />
                                <Run Foreground="{DynamicResource PipboyTextDimBrush}" Text="{TemplateBinding DisplayMaximum}" />
                            </TextBlock>
                        </Grid>

                        <!--  Discrete segment row  -->
                        <ItemsControl ItemsSource="{TemplateBinding Segments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="pipboy:SegmentItem">
                                    <Panel Width="14" Height="16">
                                        <!--  Filled segment  -->
                                        <Border
                                            Background="{DynamicResource PipboyPrimaryBrush}"
                                            IsVisible="{Binding IsFilled}" />
                                        <!--  Empty segment  -->
                                        <Border
                                            Background="{DynamicResource PipboySurfaceBrush}"
                                            BorderBrush="{DynamicResource PipboyBorderBrush}"
                                            BorderThickness="1"
                                            IsVisible="{Binding !IsFilled}" />
                                    </Panel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--
                            Continuous precision bar — displays the exact fractional fill so
                            sub-segment values are visible (e.g. 73 / 100 on a 10-segment bar
                            shows 7 lit segments but 73 % fill here).
                            Activated by ShowProgressBar="True".
                        -->
                        <ProgressBar
                            Classes="slim"
                            IsVisible="{TemplateBinding ShowProgressBar}"
                            Maximum="{TemplateBinding Maximum}"
                            Value="{TemplateBinding Value}" />

                    </StackPanel>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="{DynamicResource PipboyDisabledOpacity}" />
            </Style>
        </ControlTheme>

    </Styles.Resources>
</Styles>
