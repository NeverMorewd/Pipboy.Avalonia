<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia">

    <!--
        PipboyMap inherits from Control and does fully custom Render() drawing.
        Only set properties that Control exposes.
    -->
    <Style Selector="pipboy|PipboyMap">
        <Setter Property="MinWidth"            Value="200" />
        <Setter Property="MinHeight"           Value="150" />
        <Setter Property="Cursor"              Value="Cross" />
        <Setter Property="ClipToBounds"        Value="True" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment"   Value="Stretch" />
        <Setter Property="Focusable"           Value="True" />
    </Style>

</Styles>
