<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>

    <ControlTheme x:Key="{x:Type ProgressBar}" TargetType="ProgressBar">
      <Setter Property="Background" Value="{DynamicResource PipboySurfaceBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource PipboyPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource PipboyBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="Template">
        <ControlTemplate TargetType="ProgressBar">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <Panel>
              <!-- Indeterminate animation root.
                   Canvas children do not affect Canvas layout size, so animating
                   Canvas.Left never expands the track.  ClipToBounds hides the
                   indicator when it travels outside the track bounds. -->
              <Border Name="PART_IndeterminateRoot" IsVisible="False" ClipToBounds="True">
                <Canvas>
                  <Border Name="PART_IndeterminateIndicator"
                          Canvas.Left="-80"
                          Width="80"
                          Height="100"
                          Background="{TemplateBinding Foreground}"/>
                </Canvas>
              </Border>
              <!-- Determinate fill indicator -->
              <Border Name="PART_Indicator"
                      Background="{TemplateBinding Foreground}"
                      HorizontalAlignment="Left"
                      CornerRadius="0"/>
            </Panel>
          </Border>
        </ControlTemplate>
      </Setter>

      <Style Selector="^:indeterminate /template/ Border#PART_Indicator">
        <Setter Property="IsVisible" Value="False"/>
      </Style>
      <Style Selector="^:indeterminate /template/ Border#PART_IndeterminateRoot">
        <Setter Property="IsVisible" Value="True"/>
      </Style>
      <!-- Indeterminate: animate Canvas.Left — attached property, does not affect layout -->
      <Style Selector="^:indeterminate /template/ Border#PART_IndeterminateIndicator">
        <Style.Animations>
          <Animation Duration="0:0:1.5" IterationCount="INFINITE" Easing="LinearEasing">
            <KeyFrame Cue="0%">
              <Setter Property="Canvas.Left" Value="-80"/>
            </KeyFrame>
            <KeyFrame Cue="100%">
              <Setter Property="Canvas.Left" Value="600"/>
            </KeyFrame>
          </Animation>
        </Style.Animations>
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="0.45"/>
      </Style>
    </ControlTheme>

  </Styles.Resources>

  <!-- ── ProgressBar size variants ─────────────────────────────────────────
       slim  — 4 px, no border; inline condition bar (weapon durability, etc.)
       thick — 28 px; prominent HUD meter (main HP / AP bar)
  ─────────────────────────────────────────────────────────────────────────── -->
  <Style Selector="ProgressBar.slim">
    <Setter Property="Height"          Value="4"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <Style Selector="ProgressBar.thick">
    <Setter Property="Height" Value="28"/>
  </Style>

</Styles>
