<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>

        <!--
            EmbeddableControlRoot ControlTheme — required for WASM/Browser builds.
            In the browser, Avalonia uses EmbeddableControlRoot (not Window) as the
            top-level host. This theme MUST include VisualLayerManager so that the
            OverlayLayer exists; without it, all popup-based controls (ComboBox,
            Menu, Flyout, Notifications) silently fail to open in WASM.
        -->
        <ControlTheme x:Key="{x:Type EmbeddableControlRoot}" TargetType="EmbeddableControlRoot">
            <Setter Property="Background" Value="{DynamicResource PipboyBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PipboyTextBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource PipboyFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource PipboyFontSize}" />
            <Setter Property="Template">
                <ControlTemplate TargetType="EmbeddableControlRoot">
                    <Panel>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

    </Styles.Resources>
</Styles>
