<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>

    <!-- TabItem -->
    <ControlTheme x:Key="{x:Type TabItem}" TargetType="TabItem">
      <Setter Property="Background" Value="{DynamicResource PipboySurfaceBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource PipboyTextDimBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource PipboyBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1,1,1,0"/>
      <Setter Property="Padding" Value="14,6"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <ControlTemplate TargetType="TabItem">
          <Border Name="PART_LayoutRoot"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Margin="0,0,2,0">
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Header}"
                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                              Padding="{TemplateBinding Padding}"
                              RecognizesAccessKey="True"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
          </Border>
        </ControlTemplate>
      </Setter>

      <Style Selector="^:selected">
        <Setter Property="Background" Value="{DynamicResource PipboyPrimaryDarkBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource PipboyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PipboyPrimaryBrush}"/>
      </Style>
      <Style Selector="^:pointerover">
        <Setter Property="Background" Value="{DynamicResource PipboyHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource PipboyTextBrush}"/>
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="0.45"/>
      </Style>
    </ControlTheme>

    <!-- TabControl -->
    <ControlTheme x:Key="{x:Type TabControl}" TargetType="TabControl">
      <Setter Property="Background" Value="{DynamicResource PipboySurfaceBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource PipboyTextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource PipboyBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Template">
        <ControlTemplate TargetType="TabControl">
          <Grid RowDefinitions="Auto,*">
            <!-- Tab strip header row -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource PipboyBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource PipboySurfaceBrush}">
              <ItemsPresenter Name="PART_ItemsPresenter"
                              ItemsPanel="{TemplateBinding ItemsPanel}"/>
            </Border>
            <!-- Content area — ClipToBounds ensures the finite height is visible to children.
                 HorizontalContentAlignment/VerticalContentAlignment="Stretch" are required so
                 that ContentPresenter constrains its child to the available size (not the
                 child's natural/infinite desired size), which allows ScrollViewer inside
                 TabItem to correctly compute ViewportHeight and show the scrollbar. -->
            <Border Grid.Row="1"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="0,0,1,1"
                    ClipToBounds="True">
              <ContentPresenter Name="PART_SelectedContentHost"
                                Content="{TemplateBinding SelectedContent}"
                                ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                Margin="{TemplateBinding Padding}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>
				</Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </ControlTheme>

  </Styles.Resources>
</Styles>
