<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Global font applied to all templated controls and text blocks -->
  <Style Selector=":is(TemplatedControl)">
    <Setter Property="FontFamily" Value="{DynamicResource PipboyFontFamily}"/>
    <Setter Property="FontSize" Value="{DynamicResource PipboyFontSize}"/>
  </Style>
  <Style Selector="TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource PipboyFontFamily}"/>
    <Setter Property="FontSize" Value="{DynamicResource PipboyFontSize}"/>
  </Style>

  <!-- Per-control theme files -->
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/Button.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/TextBox.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/CheckBox.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/RadioButton.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/ToggleButton.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/ToggleSwitch.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/ProgressBar.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/Slider.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/ScrollBar.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/ListBox.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/TreeView.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/ComboBox.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/Menu.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/TabControl.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/Expander.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/NumericUpDown.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/AutoCompleteBox.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/SplitButton.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/SplitView.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/GridSplitter.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/ToolTip.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/DateTimePicker.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/FlyoutPresenter.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/Miscellaneous.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/Window.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/RepeatButton.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/HyperlinkButton.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/DropDownButton.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/DataValidationErrors.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Icons.axaml"/>
  <StyleInclude Source="avares://Pipboy.Avalonia/Styles/Controls/Notification.axaml"/>

</Styles>
