<pipboy:PipboyWindow
    x:Class="Pipboy.Avalonia.Demo.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Pipboy.Avalonia.Demo"
    xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia"
    Title="PIPBOY OS v4.0 — Theme Gallery"
    Width="1200"
    Height="760"
    MinWidth="800"
    MinHeight="560">

    <!--  Extra content injected into the title bar centre  -->
    <pipboy:PipboyWindow.TitleBarContent>
        <StackPanel
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="10">
            <TextBlock
                VerticalAlignment="Center"
                Classes="dim"
                FontSize="10"
                Text="ROBCO INDUSTRIES (TM)" />
            <TextBlock
                VerticalAlignment="Center"
                Classes="dim"
                FontSize="10"
                Text="·" />
            <pipboy:BlinkText IsBlinking="True">
                <TextBlock
                    Classes="accent"
                    FontSize="10"
                    Text="● ONLINE" />
            </pipboy:BlinkText>
        </StackPanel>
    </pipboy:PipboyWindow.TitleBarContent>

    <local:MainView />

</pipboy:PipboyWindow>
