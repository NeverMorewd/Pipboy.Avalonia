<UserControl
    x:Class="Pipboy.Avalonia.Demo.Pages.WindowPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pipboy="clr-namespace:Pipboy.Avalonia;assembly=Pipboy.Avalonia"
    x:CompileBindings="True">

    <!--  Grid: scrollable content + modal overlay on top  -->
    <Grid>

        <!--  ── Scrollable demo content  ── -->
        <ScrollViewer>
            <StackPanel Margin="24" Spacing="28">

                <TextBlock Classes="h1" Text="PIPBOY PANEL" />
                <TextBlock
                    Classes="dim"
                    Text="Borderless terminal-style floating panel. Supports accent and warning variants, optional footer, and a closable title bar."
                    TextWrapping="Wrap" />

                <!--  ══ VARIANTS ══════════════════════════════════════════  -->
                <StackPanel Spacing="10">
                    <TextBlock Classes="h2" Text="VARIANTS" />
                    <WrapPanel HorizontalAlignment="Left" ItemSpacing="16" LineSpacing="16">

                        <!--  Default  -->
                        <pipboy:PipboyPanel Width="240" Header="SYSTEM STATUS">
                            <StackPanel Spacing="5">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="dim" Text="Version" />
                                    <TextBlock Grid.Column="1" Classes="accent" Text="v4.0.2075" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="dim" Text="Uptime" />
                                    <TextBlock Grid.Column="1" Text="14d 06h 42m" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="dim" Text="Memory" />
                                    <TextBlock Grid.Column="1" Text="384 / 512 KB" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="dim" Text="Core" />
                                    <TextBlock Grid.Column="1" Text="Vault-Tec ARM" />
                                </Grid>
                            </StackPanel>
                        </pipboy:PipboyPanel>

                        <!--  Accent  -->
                        <pipboy:PipboyPanel
                            Width="240"
                            Classes="accent"
                            Header="ACTIVE QUEST">
                            <StackPanel Spacing="5">
                                <TextBlock Classes="accent" Text="THE NUCLEAR OPTION" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="10"
                                    Text="Reach the Institute relay room and activate the relay."
                                    TextWrapping="Wrap" />
                                <TextBlock Text="" />
                                <TextBlock Classes="dim" Text="[ ] Enter Institute" />
                                <TextBlock Classes="accent" Text="[✓] Find relay room" />
                                <TextBlock Classes="dim" Text="[ ] Activate relay" />
                            </StackPanel>
                        </pipboy:PipboyPanel>

                        <!--  Warning  -->
                        <pipboy:PipboyPanel
                            Width="240"
                            Classes="warning"
                            Header="RADIATION ALERT">
                            <StackPanel Spacing="5">
                                <pipboy:BlinkText IsBlinking="True">
                                    <TextBlock Classes="accent" Text="⚠ CRITICAL LEVEL" />
                                </pipboy:BlinkText>
                                <TextBlock Text="" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="dim" Text="Current" />
                                    <TextBlock Grid.Column="1" Text="450 RAD/HR" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="dim" Text="Threshold" />
                                    <TextBlock Grid.Column="1" Text="100 RAD/HR" />
                                </Grid>
                                <pipboy:SegmentedBar
                                    Maximum="600"
                                    SegmentCount="12"
                                    Value="450" />
                            </StackPanel>
                        </pipboy:PipboyPanel>

                        <!--  With footer buttons  -->
                        <pipboy:PipboyPanel
                            Width="240"
                            Classes="accent"
                            Header="CONFIRM ACTION"
                            IsClosable="True">
                            <pipboy:PipboyPanel.Footer>
                                <StackPanel
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button Content="CONFIRM" />
                                    <Button Content="CANCEL" />
                                </StackPanel>
                            </pipboy:PipboyPanel.Footer>
                            <StackPanel Spacing="6">
                                <TextBlock Text="INITIATE SELF-DESTRUCT SEQUENCE?" TextWrapping="Wrap" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="10"
                                    Text="This action cannot be undone. All vault systems will be purged."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </pipboy:PipboyPanel>

                    </WrapPanel>
                </StackPanel>

                <!--  ══ CLOSABLE / TITLE BAR ════════════════════════════  -->
                <StackPanel Spacing="10">
                    <TextBlock Classes="h2" Text="CLOSABLE PANELS" />
                    <TextBlock
                        Classes="dim"
                        Text="IsClosable=True adds a [X] button to the title bar. The Closed event lets the host decide what to do."
                        TextWrapping="Wrap" />

                    <WrapPanel HorizontalAlignment="Left" ItemSpacing="16" LineSpacing="12">

                        <pipboy:PipboyPanel
                            x:Name="InfoPanel"
                            Width="280"
                            Classes="accent"
                            Header="VAULT-TEC NOTIFICATION"
                            IsClosable="True"
                            Closed="OnPanelClosed">
                            <StackPanel Spacing="6">
                                <TextBlock Text="New firmware update available." TextWrapping="Wrap" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="10"
                                    Text="Version 4.0.3 — Stability improvements and bug fixes."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </pipboy:PipboyPanel>

                        <pipboy:PipboyPanel
                            x:Name="WarnPanel"
                            Width="280"
                            Classes="warning"
                            Header="SECURITY BREACH"
                            IsClosable="True"
                            Closed="OnPanelClosed">
                            <StackPanel Spacing="6">
                                <pipboy:BlinkText IsBlinking="True">
                                    <TextBlock Classes="accent" Text="UNAUTHORISED ACCESS DETECTED" />
                                </pipboy:BlinkText>
                                <TextBlock
                                    Classes="dim"
                                    FontSize="10"
                                    Text="Terminal locked. Contact Overseer for assistance."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </pipboy:PipboyPanel>

                        <Button Click="OnRestorePanels" Content="RESTORE PANELS" />

                    </WrapPanel>
                </StackPanel>

                <!--  ══ MODAL DIALOG DEMO ══════════════════════════════  -->
                <StackPanel Spacing="10">
                    <TextBlock Classes="h2" Text="MODAL OVERLAY" />
                    <TextBlock
                        Classes="dim"
                        Text="Overlay a PipboyPanel over page content with a semi-transparent backdrop."
                        TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Click="OnShowInfoModal"    Content="INFO DIALOG" />
                        <Button Click="OnShowConfirmModal" Content="CONFIRM DIALOG" />
                        <Button Click="OnShowWarningModal" Content="WARNING DIALOG" />
                    </StackPanel>
                </StackPanel>

                <!--  ══ INVENTORY PANEL (larger example) ═══════════════  -->
                <StackPanel Spacing="10">
                    <TextBlock Classes="h2" Text="COMPOSED LAYOUT" />
                    <TextBlock Classes="dim" Text="PipboyPanel as a structured data container." TextWrapping="Wrap" />

                    <Grid ColumnDefinitions="*,16,*" HorizontalAlignment="Left" MaxWidth="640">

                        <pipboy:PipboyPanel Grid.Column="0" Header="INVENTORY">
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="10mm Pistol" />
                                    <TextBlock Grid.Column="1" Classes="dim" Text="×1" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Stimpak" />
                                    <TextBlock Grid.Column="1" Classes="dim" Text="×12" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="RadAway" />
                                    <TextBlock Grid.Column="1" Classes="dim" Text="×4" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Fusion Core" />
                                    <TextBlock Grid.Column="1" Classes="dim" Text="×2" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Nuka-Cola" />
                                    <TextBlock Grid.Column="1" Classes="dim" Text="×7" />
                                </Grid>
                                <TextBlock Classes="dim" Text="──────────────────────" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="dim" Text="Weight" />
                                    <TextBlock Grid.Column="1" Text="24.3 / 270" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="accent" Text="CAPS" />
                                    <TextBlock Grid.Column="1" Classes="accent" Text="843" />
                                </Grid>
                            </StackPanel>
                        </pipboy:PipboyPanel>

                        <pipboy:PipboyPanel
                            Grid.Column="2"
                            Classes="accent"
                            Header="S.P.E.C.I.A.L.">
                            <pipboy:PipboyPanel.Footer>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Classes="dim"
                                        FontSize="10"
                                        Text="TOTAL POINTS: 49/70" />
                                    <Button Grid.Column="1" Content="EDIT" />
                                </Grid>
                            </pipboy:PipboyPanel.Footer>
                            <StackPanel Spacing="3">
                                <pipboy:RatedAttribute Label="STRENGTH"     Value="8" />
                                <pipboy:RatedAttribute Label="PERCEPTION"   Value="5" />
                                <pipboy:RatedAttribute Label="ENDURANCE"    Value="7" />
                                <pipboy:RatedAttribute Label="CHARISMA"     Value="4" />
                                <pipboy:RatedAttribute Label="INTELLIGENCE" Value="9" />
                                <pipboy:RatedAttribute Label="AGILITY"      Value="6" />
                                <pipboy:RatedAttribute Label="LUCK"         Value="3" />
                            </StackPanel>
                        </pipboy:PipboyPanel>

                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!--  ── Modal overlay (rendered on top of scroll content)  ── -->
        <Border
            x:Name="ModalBackdrop"
            Background="#BB000800"
            IsVisible="False">
            <pipboy:PipboyPanel
                x:Name="ModalPanel"
                Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Border>

    </Grid>

</UserControl>
