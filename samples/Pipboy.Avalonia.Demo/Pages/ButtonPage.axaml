<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Pipboy.Avalonia.Demo.Pages.ButtonPage">
  <ScrollViewer>
    <StackPanel HorizontalAlignment="Left" Margin="24" Spacing="24">

      <!-- Button -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="BUTTON"/>
        <WrapPanel>
          <Button Content="PRIMARY ACTION"   Margin="0,0,8,8"/>
          <Button Content="EXECUTE"          Margin="0,0,8,8"/>
          <Button Content="DISABLED" IsEnabled="False" Margin="0,0,8,8"/>
        </WrapPanel>
      </StackPanel>

      <!-- ToggleButton -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="TOGGLE BUTTON"/>
        <WrapPanel>
          <ToggleButton Content="VATS: OFF"                      Margin="0,0,8,8"/>
          <ToggleButton Content="VATS: ON"  IsChecked="True"     Margin="0,0,8,8"/>
          <ToggleButton Content="DISABLED"  IsEnabled="False"    Margin="0,0,8,8"/>
          <ToggleButton Content="DISABLED ON" IsEnabled="False" IsChecked="True" Margin="0,0,8,8"/>
        </WrapPanel>
      </StackPanel>

      <!-- RepeatButton -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="REPEAT BUTTON"/>
        <TextBlock Classes="dim" Text="Fires continuously while held. Use for increment / decrement."/>
        <WrapPanel>
          <RepeatButton Content="◀ HOLD" Delay="300" Interval="100" Margin="0,0,8,8"/>
          <RepeatButton Content="▶ HOLD" Delay="300" Interval="100" Margin="0,0,8,8"/>
          <RepeatButton Content="DISABLED" IsEnabled="False"         Margin="0,0,8,8"/>
        </WrapPanel>
      </StackPanel>

      <!-- SplitButton -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="SPLIT BUTTON"/>
        <WrapPanel>
          <SplitButton Content="SELECT FACTION" Margin="0,0,8,8">
            <SplitButton.Flyout>
              <MenuFlyout>
                <MenuItem Header="Brotherhood of Steel"/>
                <MenuItem Header="Railroad"/>
                <MenuItem Header="Minutemen"/>
                <MenuItem Header="Institute"/>
              </MenuFlyout>
            </SplitButton.Flyout>
          </SplitButton>
          <SplitButton Content="DISABLED" IsEnabled="False" Margin="0,0,8,8">
            <SplitButton.Flyout>
              <MenuFlyout><MenuItem Header="Item"/></MenuFlyout>
            </SplitButton.Flyout>
          </SplitButton>
        </WrapPanel>
      </StackPanel>

      <!-- DropDownButton -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="DROP-DOWN BUTTON"/>
        <WrapPanel>
          <DropDownButton Content="SELECT LOCATION" Margin="0,0,8,8">
            <DropDownButton.Flyout>
              <MenuFlyout>
                <MenuItem Header="Diamond City"/>
                <MenuItem Header="Goodneighbor"/>
                <MenuItem Header="Vault 81"/>
                <MenuItem Header="Sanctuary Hills"/>
              </MenuFlyout>
            </DropDownButton.Flyout>
          </DropDownButton>
          <DropDownButton Content="DISABLED" IsEnabled="False" Margin="0,0,8,8">
            <DropDownButton.Flyout>
              <MenuFlyout><MenuItem Header="Item"/></MenuFlyout>
            </DropDownButton.Flyout>
          </DropDownButton>
        </WrapPanel>
      </StackPanel>

      <!-- HyperlinkButton -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="HYPERLINK BUTTON"/>
        <HyperlinkButton Content="Open Vault-Tec official records" NavigateUri="https://www.fallout.com"/>
        <HyperlinkButton Content="Check SPECIAL stats"/>
        <HyperlinkButton Content="Disabled link" IsEnabled="False"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
