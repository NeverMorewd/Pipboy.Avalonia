<UserControl
    x:Class="Pipboy.Avalonia.Demo.Pages.TreeViewPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="True">
    <Grid RowDefinitions="Auto,*">

        <Border
            Grid.Row="0"
            BorderBrush="{DynamicResource PipboyBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,16">
            <StackPanel Spacing="3">
                <TextBlock Classes="h1" Text="TREE VIEW" />
                <TextBlock
                    Classes="dim"
                    FontSize="11"
                    Text="Hierarchical data display. Nodes expand and collapse; keyboard navigation with arrow keys." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="24,20" Spacing="20">

                <!--  ── Static tree + usage notes ── -->
                <Grid ColumnDefinitions="*,20,340">

                    <HeaderedContentControl Grid.Column="0" Classes="groupbox" Header="SKILL TREE — STATIC ITEMS">
                        <TreeView>
                            <TreeViewItem Header="SPECIAL ATTRIBUTES" IsExpanded="True">
                                <TreeViewItem Header="Strength      — 7" />
                                <TreeViewItem Header="Perception    — 6" />
                                <TreeViewItem Header="Endurance     — 5" />
                                <TreeViewItem Header="Charisma      — 8" />
                                <TreeViewItem Header="Intelligence  — 9" />
                                <TreeViewItem Header="Agility       — 6" />
                                <TreeViewItem Header="Luck          — 7" />
                            </TreeViewItem>
                            <TreeViewItem Header="PERKS" IsExpanded="True">
                                <TreeViewItem Header="Rifleman" IsExpanded="True">
                                    <TreeViewItem Header="Rank 1 — +20% rifle damage" />
                                    <TreeViewItem Header="Rank 2 — +40% rifle damage" />
                                    <TreeViewItem Header="Rank 3 — Ignore 30% armor" />
                                </TreeViewItem>
                                <TreeViewItem Header="Sneak">
                                    <TreeViewItem Header="Rank 1 — Harder to detect" />
                                    <TreeViewItem Header="Rank 2 — No noise in light armor" />
                                </TreeViewItem>
                                <TreeViewItem Header="Hacker">
                                    <TreeViewItem Header="Rank 1 — Hack novice terminals" />
                                    <TreeViewItem Header="Rank 2 — Hack advanced terminals" />
                                </TreeViewItem>
                                <TreeViewItem Header="Locksmith">
                                    <TreeViewItem Header="Rank 1 — Pick novice locks" />
                                </TreeViewItem>
                            </TreeViewItem>
                            <TreeViewItem Header="CRAFTING">
                                <TreeViewItem Header="Armorer" />
                                <TreeViewItem Header="Blacksmith" />
                                <TreeViewItem Header="Science!" />
                                <TreeViewItem Header="Gun Nut" />
                            </TreeViewItem>
                            <TreeViewItem Header="COMPANIONS (leaf node — no children)" />
                        </TreeView>
                    </HeaderedContentControl>

                    <HeaderedContentControl Grid.Column="2" Classes="groupbox" Header="USAGE GUIDE">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="accent" FontSize="11" Text="STATIC ITEMS" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="11"
                                    Text="Nest TreeViewItem elements directly in XAML. Set IsExpanded=True to pre-expand a node."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Classes="accent" FontSize="11" Text="DATA BINDING (MVVM)" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="11"
                                    Text="Bind ItemsSource to an ObservableCollection of nodes. Use HierarchicalDataTemplate to map child collections automatically."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Classes="accent" FontSize="11" Text="KEYBOARD NAVIGATION" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="11"
                                    Text="← collapses a node.  → expands it.  ↑ / ↓ move between visible items.  Enter or Space selects."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Classes="accent" FontSize="11" Text="SELECTION" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="11"
                                    Text="Bind SelectedItem or handle SelectionChanged to react to node selection."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Classes="accent" FontSize="11" Text="VIRTUALIZATION" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="11"
                                    Text="Large trees use UI virtualization automatically — only visible rows are rendered."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </HeaderedContentControl>

                </Grid>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
