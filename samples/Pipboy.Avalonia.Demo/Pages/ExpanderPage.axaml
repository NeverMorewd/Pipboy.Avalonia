<UserControl
    x:Class="Pipboy.Avalonia.Demo.Pages.ExpanderPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="True">
    <Grid RowDefinitions="Auto,*">

        <Border
            Grid.Row="0"
            BorderBrush="{DynamicResource PipboyBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,16">
            <StackPanel Spacing="3">
                <TextBlock Classes="h1" Text="COLLAPSIBLE PANELS" />
                <TextBlock
                    Classes="dim"
                    FontSize="11"
                    Text="Expander, SplitView, and GridSplitter — progressive disclosure and resizable layout controls." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="24,20" Spacing="20">

                <!--  ── Expander ── -->
                <HeaderedContentControl Classes="groupbox" Header="EXPANDER">
                    <Grid ColumnDefinitions="*,20,*">

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock
                                Margin="0,0,0,4"
                                Classes="dim"
                                FontSize="11"
                                Text="Click the header to expand / collapse. Set IsExpanded=True to start open."
                                TextWrapping="Wrap" />
                            <Expander Header="WEAPON STATS" IsExpanded="True">
                                <Grid
                                    Margin="8,4"
                                    ColumnDefinitions="120,*"
                                    RowDefinitions="Auto,4,Auto,4,Auto,4,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="dim" Text="Damage:" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="85" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="dim" Text="Fire Rate:" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="6" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="dim" Text="Range:" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="119" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Classes="dim" Text="Accuracy:" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="69" />
                                </Grid>
                            </Expander>
                            <Expander Header="ARMOR STATS">
                                <Grid
                                    Margin="8,4"
                                    ColumnDefinitions="120,*"
                                    RowDefinitions="Auto,4,Auto,4,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="dim" Text="Ballistic DR:" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="42" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="dim" Text="Energy DR:" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="38" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="dim" Text="Radiation DR:" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="15" />
                                </Grid>
                            </Expander>
                            <Expander Header="COMPANION DATA  (disabled)" IsEnabled="False" />
                            <Expander Header="EXTRA MODS  (collapsed by default)" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="accent" FontSize="11" Text="ACCORDION PATTERN" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="11"
                                    Text="Stack multiple Expanders to build a settings-style accordion. Each expands independently unless you manage IsExpanded in code."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Classes="accent" FontSize="11" Text="PROPERTIES" />
                                <TextBlock
                                    Classes="dim"
                                    FontSize="11"
                                    Text="Header — the toggle label. IsExpanded — open/closed state (bindable). ExpandDirection — Down (default), Up, Left, Right."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </HeaderedContentControl>

                <!--  ── SplitView ── -->
                <HeaderedContentControl Classes="groupbox" Header="SPLIT VIEW">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Classes="dim"
                            FontSize="11"
                            Text="Provides a collapsible side pane alongside a main content area. DisplayMode: Inline (pane shifts content) or Overlay (pane floats above content). Toggle IsPaneOpen to show/hide."
                            TextWrapping="Wrap" />
                        <Border
                            Height="160"
                            BorderBrush="{DynamicResource PipboyBorderBrush}"
                            BorderThickness="1">
                            <SplitView
                                DisplayMode="Inline"
                                IsPaneOpen="True"
                                OpenPaneLength="150">
                                <SplitView.Pane>
                                    <StackPanel Margin="12,10" Spacing="2">
                                        <TextBlock
                                            Margin="0,0,0,6"
                                            Classes="dim"
                                            FontSize="10"
                                            Text="NAVIGATION" />
                                        <TextBlock Text="STATUS" />
                                        <TextBlock Text="INVENTORY" />
                                        <TextBlock Text="QUESTS" />
                                        <TextBlock Text="MAP" />
                                        <TextBlock Text="RADIO" />
                                    </StackPanel>
                                </SplitView.Pane>
                                <TextBlock
                                    Margin="16"
                                    VerticalAlignment="Center"
                                    Classes="dim"
                                    Text="Main content area — SplitView shifts this region when the pane opens in Inline mode."
                                    TextWrapping="Wrap" />
                            </SplitView>
                        </Border>
                    </StackPanel>
                </HeaderedContentControl>

                <!--  ── GridSplitter ── -->
                <HeaderedContentControl Classes="groupbox" Header="GRID SPLITTER">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Classes="dim"
                            FontSize="11"
                            Text="Drag the splitter bar to resize adjacent Grid columns or rows interactively. Place in a Grid cell between the resizable regions."
                            TextWrapping="Wrap" />
                        <Border
                            Height="130"
                            BorderBrush="{DynamicResource PipboyBorderBrush}"
                            BorderThickness="1">
                            <Grid ColumnDefinitions="*,5,*">
                                <StackPanel Grid.Column="0" Margin="12,10" Spacing="4">
                                    <TextBlock Classes="dim" FontSize="10" Text="LEFT PANEL" />
                                    <TextBlock
                                        Classes="dim"
                                        Text="Drag the divider right to give more space to this panel."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <GridSplitter
                                    Grid.Column="1"
                                    Width="5"
                                    ResizeDirection="Columns" />
                                <StackPanel Grid.Column="2" Margin="12,10" Spacing="4">
                                    <TextBlock Classes="dim" FontSize="10" Text="RIGHT PANEL" />
                                    <TextBlock
                                        Classes="dim"
                                        Text="Drag left to give more space here."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </HeaderedContentControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
