<UserControl
    x:Class="Pipboy.Avalonia.Demo.Pages.ExpanderPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel
            Margin="24"
            HorizontalAlignment="Left"
            Spacing="24">

            <!--  Expander  -->
            <StackPanel Spacing="8">
                <TextBlock Classes="h2" Text="EXPANDER" />
                <StackPanel Width="440" Spacing="6">
                    <Expander Header="WEAPON STATS" IsExpanded="True">
                        <Grid
                            Margin="8"
                            ColumnDefinitions="120,*"
                            RowDefinitions="Auto,4,Auto,4,Auto,4,Auto">
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Classes="dim"
                                Text="Damage:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="85" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Classes="dim"
                                Text="Fire Rate:" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="6" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Classes="dim"
                                Text="Range:" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                Text="119" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                Classes="dim"
                                Text="Accuracy:" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="1"
                                Text="69" />
                        </Grid>
                    </Expander>
                    <Expander Header="ARMOR STATS">
                        <Grid
                            Margin="8"
                            ColumnDefinitions="120,*"
                            RowDefinitions="Auto,4,Auto,4,Auto">
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Classes="dim"
                                Text="Ballistic:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="42" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Classes="dim"
                                Text="Energy:" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="38" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Classes="dim"
                                Text="Radiation:" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                Text="15" />
                        </Grid>
                    </Expander>
                    <Expander Header="COMPANION DATA (disabled)" IsEnabled="False" />
                    <Expander Header="CLOSED SECTION" />
                </StackPanel>
            </StackPanel>

            <!--  SplitView  -->
            <StackPanel Spacing="8">
                <TextBlock Classes="h2" Text="SPLIT VIEW" />
                <Border
                    Width="440"
                    Height="150"
                    BorderBrush="{DynamicResource PipboyBorderBrush}"
                    BorderThickness="1">
                    <SplitView
                        DisplayMode="Inline"
                        IsPaneOpen="True"
                        OpenPaneLength="140">
                        <SplitView.Pane>
                            <StackPanel Margin="10">
                                <TextBlock
                                    Margin="0,0,0,6"
                                    Classes="dim"
                                    FontSize="10"
                                    Text="NAVIGATION" />
                                <TextBlock Margin="0,0,0,4" Text="STATUS" />
                                <TextBlock Margin="0,0,0,4" Text="INVENTORY" />
                                <TextBlock Margin="0,0,0,4" Text="QUESTS" />
                                <TextBlock Text="MAP" />
                            </StackPanel>
                        </SplitView.Pane>
                        <TextBlock
                            Margin="14"
                            Text="Main content area. SplitView provides a collapsible side panel for navigation or detail views."
                            TextWrapping="Wrap" />
                    </SplitView>
                </Border>
            </StackPanel>

            <!--  GridSplitter  -->
            <StackPanel Spacing="8">
                <TextBlock Classes="h2" Text="GRID SPLITTER" />
                <Border
                    Width="440"
                    Height="120"
                    BorderBrush="{DynamicResource PipboyBorderBrush}"
                    BorderThickness="1">
                    <Grid ColumnDefinitions="*,5,*">
                        <TextBlock
                            Grid.Column="0"
                            Margin="10"
                            Classes="dim"
                            Text="Left panel — Drag the splitter to resize."
                            TextWrapping="Wrap" />
                        <GridSplitter
                            Grid.Column="1"
                            Width="5"
                            ResizeDirection="Columns" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="10"
                            Classes="dim"
                            Text="Right panel content area."
                            TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
