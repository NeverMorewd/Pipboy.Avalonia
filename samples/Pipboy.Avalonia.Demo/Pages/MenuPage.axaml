<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Pipboy.Avalonia.Demo.Pages.MenuPage">
  <ScrollViewer>
    <StackPanel HorizontalAlignment="Left" Margin="24" Spacing="24">

      <!-- Menu Bar -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="MENU BAR"/>
        <TextBlock Classes="dim" Text="Top-level items open downward. Hover across items to switch menus. Supports unlimited submenu depth."/>
        <Menu>
          <MenuItem Header="FILE">
            <MenuItem Header="New"       InputGesture="Ctrl+N"/>
            <MenuItem Header="Open"      InputGesture="Ctrl+O"/>
            <MenuItem Header="Open Recent">
              <MenuItem Header="vault_save_01.pip"/>
              <MenuItem Header="vault_save_02.pip"/>
              <MenuItem Header="wasteland_log.pip"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Save"      InputGesture="Ctrl+S"/>
            <MenuItem Header="Save As…"  InputGesture="Ctrl+Shift+S"/>
            <Separator/>
            <MenuItem Header="Exit"/>
          </MenuItem>
          <MenuItem Header="EDIT">
            <MenuItem Header="Undo"  InputGesture="Ctrl+Z"/>
            <MenuItem Header="Redo"  InputGesture="Ctrl+Y"/>
            <Separator/>
            <MenuItem Header="Cut"   InputGesture="Ctrl+X"/>
            <MenuItem Header="Copy"  InputGesture="Ctrl+C"/>
            <MenuItem Header="Paste" InputGesture="Ctrl+V"/>
            <Separator/>
            <MenuItem Header="Select All" InputGesture="Ctrl+A"/>
          </MenuItem>
          <MenuItem Header="VIEW">
            <MenuItem Header="Zoom">
              <MenuItem Header="Zoom In"  InputGesture="Ctrl+Add"/>
              <MenuItem Header="Zoom Out" InputGesture="Ctrl+Subtract"/>
              <MenuItem Header="Reset"    InputGesture="Ctrl+D0"/>
            </MenuItem>
            <MenuItem Header="Theme">
              <MenuItem Header="Pipboy Green"/>
              <MenuItem Header="Amber"/>
              <MenuItem Header="Nord"/>
              <MenuItem Header="Cobalt"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="Full Screen" InputGesture="F11"/>
          </MenuItem>
          <MenuItem Header="HELP" IsEnabled="False"/>
        </Menu>
      </StackPanel>

      <!-- Context Menu -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="CONTEXT MENU"/>
        <TextBlock Classes="dim" Text="Right-click the target area below to open the context menu with nested submenus."/>
        <Border Background="{DynamicResource PipboySurfaceBrush}"
                BorderBrush="{DynamicResource PipboyBorderBrush}"
                BorderThickness="1"
                Padding="16,12"
                Width="320" HorizontalAlignment="Left">
          <TextBlock Classes="dim" Text="› RIGHT-CLICK HERE ‹"
                     HorizontalAlignment="Center"/>
          <Border.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Inspect"     Click="OnMenuItemClick"/>
              <MenuItem Header="Mark Target" Click="OnMenuItemClick"/>
              <MenuItem Header="Tag As">
                <MenuItem Header="Enemy"   Click="OnMenuItemClick"/>
                <MenuItem Header="Neutral" Click="OnMenuItemClick"/>
                <MenuItem Header="Friendly">
                  <MenuItem Header="Brotherhood" Click="OnMenuItemClick"/>
                  <MenuItem Header="Minutemen"   Click="OnMenuItemClick"/>
                  <MenuItem Header="Railroad"    Click="OnMenuItemClick"/>
                </MenuItem>
              </MenuItem>
              <Separator/>
              <MenuItem Header="Properties…" Click="OnMenuItemClick"/>
              <MenuItem Header="Delete"      Click="OnMenuItemClick" IsEnabled="False"/>
            </ContextMenu>
          </Border.ContextMenu>
        </Border>
        <TextBlock Name="MenuStatusText" Classes="dim" Text="No item selected."/>
      </StackPanel>

      <!-- Menu Flyout -->
      <StackPanel Spacing="8">
        <TextBlock Classes="h2" Text="MENU FLYOUT"/>
        <TextBlock Classes="dim" Text="Button-triggered menu with submenus. Dismiss by selecting an item, pressing Esc, or clicking outside."/>
        <WrapPanel>
          <Button Name="MenuFlyoutBtn" Content="ACTIONS ▾" Margin="0,0,8,8"
                  Click="OnMenuFlyoutBtnClick">
            <Button.Flyout>
              <MenuFlyout Placement="Bottom">
                <MenuItem Header="Take item"   Click="OnMenuItemClick"/>
                <MenuItem Header="Inspect"     Click="OnMenuItemClick"/>
                <MenuItem Header="Send to">
                  <MenuItem Header="Inventory" Click="OnMenuItemClick"/>
                  <MenuItem Header="Workbench" Click="OnMenuItemClick"/>
                  <MenuItem Header="Companion">
                    <MenuItem Header="Dogmeat"   Click="OnMenuItemClick"/>
                    <MenuItem Header="Codsworth"  Click="OnMenuItemClick"/>
                    <MenuItem Header="Piper"      Click="OnMenuItemClick"/>
                  </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Discard" Click="OnMenuItemClick"/>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
          <Button Content="DISABLED ▾" IsEnabled="False" Margin="0,0,8,8">
            <Button.Flyout>
              <MenuFlyout><MenuItem Header="Not reachable"/></MenuFlyout>
            </Button.Flyout>
          </Button>
        </WrapPanel>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
