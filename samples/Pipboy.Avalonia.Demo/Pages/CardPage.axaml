<UserControl
    x:Class="Pipboy.Avalonia.Demo.Pages.CardPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="True">
    <Grid RowDefinitions="Auto,*">

        <Border
            Grid.Row="0"
            BorderBrush="{DynamicResource PipboyBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,16">
            <StackPanel Spacing="3">
                <TextBlock Classes="h1" Text="CARDS &amp; SURFACES" />
                <TextBlock
                    Classes="dim"
                    FontSize="11"
                    Text="Border class variants for surface containers: card, card-elevated, terminal, hud. Plus Separator for section dividers." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="24,20" Spacing="20">

                <!--  ── card ── -->
                <HeaderedContentControl Classes="groupbox" Header="CARD  (Classes=&quot;card&quot;)">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Classes="dim"
                            FontSize="11"
                            Text="Surface background, theme border, 16px padding. Use for entity cards, info panels, and grouped content blocks."
                            TextWrapping="Wrap" />
                        <WrapPanel>
                            <Border
                                Width="200"
                                Margin="0,0,12,12"
                                Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="h2" Text="VAULT 101" />
                                    <TextBlock Classes="dim" Text="Status: Sealed" />
                                    <TextBlock Text="Population: 0" />
                                    <Separator />
                                    <TextBlock Classes="dim" FontSize="10" Text="Capital Wasteland" />
                                </StackPanel>
                            </Border>
                            <Border
                                Width="200"
                                Margin="0,0,12,12"
                                Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="h2" Text="VAULT 81" />
                                    <TextBlock Classes="dim" Text="Status: Active" />
                                    <TextBlock Text="Population: 42" />
                                    <Separator />
                                    <TextBlock Classes="dim" FontSize="10" Text="Commonwealth" />
                                </StackPanel>
                            </Border>
                            <Border
                                Width="200"
                                Margin="0,0,12,12"
                                Classes="card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="h2" Text="VAULT 111" />
                                    <TextBlock Classes="dim" Text="Status: Abandoned" />
                                    <TextBlock Text="Population: 1" />
                                    <Separator />
                                    <TextBlock Classes="dim" FontSize="10" Text="Commonwealth" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </HeaderedContentControl>

                <!--  ── card-elevated ── -->
                <HeaderedContentControl Classes="groupbox" Header="ELEVATED CARD  (Classes=&quot;card-elevated&quot;)">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Classes="dim"
                            FontSize="11"
                            Text="Raised surface with primary-color border accent. Use to draw attention to featured content or selected items."
                            TextWrapping="Wrap" />
                        <WrapPanel>
                            <Border
                                Width="220"
                                Margin="0,0,12,12"
                                Classes="card-elevated">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="h2" Text="DIAMOND CITY" />
                                    <TextBlock Classes="dim" Text="Commonwealth — Major Settlement" />
                                    <TextBlock Text="Traders: 12 · Guards: 8" />
                                    <TextBlock Classes="accent" Text="STATUS: SECURE" />
                                </StackPanel>
                            </Border>
                            <Border
                                Width="220"
                                Margin="0,0,12,12"
                                Classes="card-elevated">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="h2" Text="GOODNEIGHBOR" />
                                    <TextBlock Classes="dim" Text="Commonwealth — Neutral Zone" />
                                    <TextBlock Text="Traders: 7 · Gangers: 20" />
                                    <TextBlock Classes="accent" Text="STATUS: VOLATILE" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </HeaderedContentControl>

                <!--  ── terminal + hud ── -->
                <Grid ColumnDefinitions="*,16,*">

                    <HeaderedContentControl Grid.Column="0" Classes="groupbox" Header="TERMINAL  (Classes=&quot;terminal&quot;)">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Classes="dim"
                                FontSize="11"
                                Text="Black background with primary-color border. Resembles a CRT terminal readout or Pip-Boy screen section."
                                TextWrapping="Wrap" />
                            <Border Classes="terminal">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="accent" Text="ROBCO TERMLINK v2.3.1" />
                                    <TextBlock Classes="dim" Text="&gt; CONNECTING TO MAINFRAME..." />
                                    <TextBlock Classes="dim" Text="&gt; AUTH OK. WELCOME, OVERSEER." />
                                    <TextBlock Text="&gt; READY_" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Grid.Column="2" Classes="groupbox" Header="HUD  (Classes=&quot;hud&quot;)">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Classes="dim"
                                FontSize="11"
                                Text="Compact data block with standard border and tight padding. Use for HP/AP/Caps counters and small stat readouts."
                                TextWrapping="Wrap" />
                            <WrapPanel>
                                <Border Margin="0,0,8,8" Classes="hud">
                                    <StackPanel>
                                        <TextBlock Classes="dim" FontSize="10" Text="HP" />
                                        <TextBlock Classes="accent" Text="72 / 100" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,8" Classes="hud">
                                    <StackPanel>
                                        <TextBlock Classes="dim" FontSize="10" Text="AP" />
                                        <TextBlock Classes="accent" Text="45 / 100" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,8" Classes="hud">
                                    <StackPanel>
                                        <TextBlock Classes="dim" FontSize="10" Text="CAPS" />
                                        <TextBlock Classes="accent" Text="843" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,8" Classes="hud">
                                    <StackPanel>
                                        <TextBlock Classes="dim" FontSize="10" Text="LVL" />
                                        <TextBlock Classes="accent" Text="42" />
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </HeaderedContentControl>

                </Grid>

                <!--  ── Separator ── -->
                <HeaderedContentControl Classes="groupbox" Header="SEPARATOR">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Classes="dim"
                            FontSize="11"
                            Text="A 1px horizontal divider line. Use between logical sections inside cards, panels, list headers, or menu groups."
                            TextWrapping="Wrap" />
                        <StackPanel MaxWidth="400" HorizontalAlignment="Left" Spacing="8">
                            <TextBlock Text="Section A — Primary Systems" />
                            <Separator />
                            <TextBlock Text="Section B — Auxiliary Systems" />
                            <Separator />
                            <TextBlock Text="Section C — Emergency Protocols" />
                        </StackPanel>
                    </StackPanel>
                </HeaderedContentControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
