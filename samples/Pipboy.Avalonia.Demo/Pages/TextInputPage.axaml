<UserControl
    x:Class="Pipboy.Avalonia.Demo.Pages.TextInputPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel
            Margin="24"
            HorizontalAlignment="Left"
            Spacing="24">

            <!--  TextBox  -->
            <StackPanel Spacing="8">
                <TextBlock Classes="h2" Text="TEXT BOX" />
                <TextBox Width="360" Watermark="Enter terminal command..." />
                <TextBox Width="360" Text="Editable text field" />
                <TextBox
                    Width="360"
                    PasswordChar="●"
                    Watermark="Password" />
                <TextBox
                    Width="360"
                    IsReadOnly="True"
                    Text="Read-only field" />
                <TextBox
                    Width="360"
                    Height="80"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Watermark="Multi-line... (Shift+Enter)" />
            </StackPanel>

            <!--  AutoCompleteBox  -->
            <StackPanel Spacing="8">
                <TextBlock Classes="h2" Text="AUTO COMPLETE BOX" />
                <TextBlock Classes="dim" Text="Items loaded from code-behind." />
                <AutoCompleteBox
                    Name="LocationAutoComplete"
                    Width="360"
                    Watermark="Search locations..." />
            </StackPanel>

            <!--  NumericUpDown  -->
            <StackPanel Spacing="8">
                <TextBlock Classes="h2" Text="NUMERIC UP-DOWN" />
                <WrapPanel>
                    <NumericUpDown
                        Width="160"
                        Margin="0,0,12,8"
                        Maximum="100"
                        Minimum="0"
                        Value="42" />
                    <NumericUpDown
                        Width="160"
                        Margin="0,0,12,8"
                        FormatString="F2"
                        Increment="0.01"
                        Maximum="9.99"
                        Minimum="0"
                        Value="3.14" />
                    <NumericUpDown
                        Width="160"
                        Margin="0,0,12,8"
                        IsEnabled="False"
                        Value="7" />
                </WrapPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
