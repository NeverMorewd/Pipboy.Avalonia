<Window
    x:Class="Pipboy.Avalonia.Sample.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PIPBOY OS v4.0 — Theme Gallery"
    Width="1000"
    Height="720"
    MinWidth="800"
    MinHeight="560">

    <Grid RowDefinitions="Auto,*">

        <!--  Menu bar  -->
        <Menu Grid.Row="0">
            <MenuItem Header="_FILE">
                <MenuItem Header="_New" />
                <MenuItem Header="_Open" />
                <Separator />
                <MenuItem Header="_Exit" />
            </MenuItem>
            <MenuItem Header="_VIEW">
                <MenuItem Header="_Status" />
                <MenuItem Header="_Inventory" />
                <MenuItem Header="_MAP" />
            </MenuItem>
            <MenuItem Header="_WINDOW">
                <MenuItem Click="OnOpenDialog" Header="_Open Dialog Window" />
            </MenuItem>
            <MenuItem Header="_HELP">
                <MenuItem Header="_About" />
            </MenuItem>
        </Menu>

        <!--  Main content  -->
        <TabControl Grid.Row="1" Margin="8">

            <!--  ===== Tab 1: Basic Controls =====  -->
            <TabItem Header="[ BASIC ]">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <!--  Buttons  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="BUTTONS" />
                        <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                            <Button Margin="0,0,8,0" Content="PRIMARY ACTION" />
                            <Button
                                Margin="0,0,8,0"
                                Content="DISABLED"
                                IsEnabled="False" />
                            <Button Margin="0,0,8,0" Content="▶ EXECUTE" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                            <ToggleButton Margin="0,0,8,0" Content="TOGGLE OFF" />
                            <ToggleButton
                                Margin="0,0,8,0"
                                Content="TOGGLE ON"
                                IsChecked="True" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                            <SplitButton Margin="0,0,8,0" Content="SPLIT ACTION">
                                <SplitButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Option A" />
                                        <MenuItem Header="Option B" />
                                        <MenuItem Header="Option C" />
                                    </MenuFlyout>
                                </SplitButton.Flyout>
                            </SplitButton>
                        </StackPanel>

                        <!--  TextBox  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="INPUT FIELDS" />
                        <StackPanel
                            MaxWidth="400"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left">
                            <TextBox Margin="0,0,0,6" Watermark="Enter terminal command..." />
                            <TextBox Margin="0,0,0,6" Text="Editable text field" />
                            <TextBox
                                Margin="0,0,0,6"
                                PasswordChar="●"
                                Watermark="Password field" />
                            <TextBox
                                Margin="0,0,0,6"
                                IsReadOnly="True"
                                Text="Read-only" />
                            <AutoCompleteBox Watermark="Auto-complete search..." />
                        </StackPanel>

                        <!--  NumericUpDown  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="NUMERIC INPUT" />
                        <StackPanel
                            MaxWidth="500"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left"
                            Orientation="Horizontal">
                            <NumericUpDown
                                Width="160"
                                Margin="0,0,12,0"
                                Maximum="100"
                                Minimum="0"
                                Value="42" />
                            <NumericUpDown
                                Width="160"
                                FormatString="F2"
                                Increment="0.01"
                                Maximum="9.99"
                                Minimum="0"
                                Value="3.14" />
                        </StackPanel>

                        <!--  CheckBox / RadioButton / ToggleSwitch  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="TOGGLES" />
                        <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                            <StackPanel Margin="0,0,32,0">
                                <CheckBox
                                    Margin="0,0,0,6"
                                    Content="VATS ENABLED"
                                    IsChecked="True" />
                                <CheckBox
                                    Margin="0,0,0,6"
                                    Content="AUTO-SAVE"
                                    IsChecked="False" />
                                <CheckBox
                                    Margin="0,0,0,6"
                                    Content="INDETERMINATE"
                                    IsChecked="{x:Null}" />
                                <CheckBox Content="DISABLED" IsEnabled="False" />
                            </StackPanel>
                            <StackPanel Margin="0,0,32,0">
                                <RadioButton
                                    Margin="0,0,0,6"
                                    Content="NORMAL"
                                    GroupName="diff"
                                    IsChecked="True" />
                                <RadioButton
                                    Margin="0,0,0,6"
                                    Content="HARD"
                                    GroupName="diff" />
                                <RadioButton Content="SURVIVAL" GroupName="diff" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Classes="dim"
                                    Text="HUD ENABLED" />
                                <ToggleSwitch Margin="0,0,0,8" IsChecked="True" />
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Classes="dim"
                                    Text="SUBTITLES" />
                                <ToggleSwitch IsChecked="False" />
                            </StackPanel>
                        </StackPanel>

                        <!--  Meters  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="METERS &amp; SLIDERS" />
                        <Grid
                            MaxWidth="500"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Classes="dim"
                                Text="HP:" />
                            <ProgressBar
                                Grid.Row="0"
                                Grid.Column="1"
                                Maximum="100"
                                Value="75" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Classes="dim"
                                Text="AP:" />
                            <ProgressBar
                                Grid.Row="2"
                                Grid.Column="1"
                                Maximum="100"
                                Value="50" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Classes="dim"
                                Text="RAD:" />
                            <ProgressBar
                                Grid.Row="4"
                                Grid.Column="1"
                                Maximum="100"
                                Value="20" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Classes="dim"
                                Text="INDET:" />
                            <ProgressBar
                                Grid.Row="6"
                                Grid.Column="1"
                                IsIndeterminate="True" />
                            <TextBlock
                                Grid.Row="8"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Classes="dim"
                                Text="VOL:" />
                            <Slider
                                Grid.Row="8"
                                Grid.Column="1"
                                Maximum="100"
                                Value="65" />
                            <TextBlock
                                Grid.Row="10"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Classes="dim"
                                Text="BRIG:" />
                            <Slider
                                Grid.Row="10"
                                Grid.Column="1"
                                Maximum="100"
                                Value="80" />
                        </Grid>

                        <!--  Typography  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="TYPOGRAPHY" />
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Classes="h1" Text="HEADING LEVEL 1" />
                            <TextBlock
                                Margin="0,4,0,4"
                                Classes="h2"
                                Text="Heading Level 2" />
                            <TextBlock Text="Regular body text — Normal paragraph content goes here." />
                            <TextBlock
                                Margin="0,4,0,4"
                                Classes="dim"
                                Text="Dimmed / secondary text for labels and hints." />
                            <TextBlock Classes="accent" Text="Accent text — primary color highlight." />
                            <SelectableTextBlock Margin="0,4,0,0" Text="Selectable text — you can highlight this." />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Tab 2: Lists & Selection =====  -->
            <TabItem Header="[ LISTS ]">
                <Grid Margin="12" ColumnDefinitions="*,8,*">

                    <!--  Left: ListBox + ComboBox + AutoComplete  -->
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="LIST BOX — INVENTORY" />
                        <ListBox Height="160" Margin="0,0,0,16">
                            <ListBoxItem Content="10mm Pistol          x1" />
                            <ListBoxItem Content="Stimpak              x12" />
                            <ListBoxItem Content="RadAway              x4" />
                            <ListBoxItem Content="Nuka-Cola             x7" />
                            <ListBoxItem Content="Fusion Core           x2" />
                            <ListBoxItem Content="Bobby Pin             x99" />
                        </ListBox>

                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="COMBO BOX — LOCATION" />
                        <ComboBox
                            Width="260"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left"
                            SelectedIndex="0">
                            <ComboBoxItem Content="DIAMOND CITY" />
                            <ComboBoxItem Content="GOODNEIGHBOR" />
                            <ComboBoxItem Content="THE INSTITUTE" />
                            <ComboBoxItem Content="VAULT 81" />
                            <ComboBoxItem Content="SANCTUARY HILLS" />
                        </ComboBox>

                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="SECOND LIST — PERKS" />
                        <ListBox Height="200">
                            <ListBoxItem Content="Rifleman        Rank 3" />
                            <ListBoxItem Content="Sneak           Rank 2" />
                            <ListBoxItem Content="Hacker          Rank 2" />
                            <ListBoxItem Content="Locksmith       Rank 1" />
                            <ListBoxItem Content="Medic           Rank 1" />
                            <ListBoxItem Content="Toughness       Rank 2" />
                            <ListBoxItem Content="Gun Nut         Rank 3" />
                            <ListBoxItem Content="Science!        Rank 1" />
                        </ListBox>
                    </StackPanel>

                    <!--  Separator  -->
                    <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

                    <!--  Right: TreeView  -->
                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="TREE VIEW — SKILL TREE" />
                        <TreeView>
                            <TreeViewItem Header="SPECIAL ATTRIBUTES" IsExpanded="True">
                                <TreeViewItem Header="Strength — 7" />
                                <TreeViewItem Header="Perception — 6" />
                                <TreeViewItem Header="Endurance — 5" />
                                <TreeViewItem Header="Charisma — 8" />
                                <TreeViewItem Header="Intelligence — 9" />
                                <TreeViewItem Header="Agility — 6" />
                                <TreeViewItem Header="Luck — 7" />
                            </TreeViewItem>
                            <TreeViewItem Header="PERKS" IsExpanded="True">
                                <TreeViewItem Header="Rifleman" IsExpanded="True">
                                    <TreeViewItem Header="Rank 1 — +20% rifle damage" />
                                    <TreeViewItem Header="Rank 2 — +40% rifle damage" />
                                    <TreeViewItem Header="Rank 3 — Ignore 30% armor" />
                                </TreeViewItem>
                                <TreeViewItem Header="Sneak">
                                    <TreeViewItem Header="Rank 1 — Harder to detect" />
                                    <TreeViewItem Header="Rank 2 — No noise in armor" />
                                </TreeViewItem>
                                <TreeViewItem Header="Hacker">
                                    <TreeViewItem Header="Rank 1 — Hack novice terminals" />
                                    <TreeViewItem Header="Rank 2 — Hack advanced terminals" />
                                </TreeViewItem>
                            </TreeViewItem>
                            <TreeViewItem Header="CRAFTING">
                                <TreeViewItem Header="Armorer" />
                                <TreeViewItem Header="Blacksmith" />
                                <TreeViewItem Header="Science!" />
                            </TreeViewItem>
                            <TreeViewItem Header="COMPANIONS — No children (leaf node)" />
                        </TreeView>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!--  ===== Tab 3: Layout Controls =====  -->
            <TabItem Header="[ LAYOUT ]">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <!--  Expander  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="EXPANDER" />
                        <StackPanel
                            MaxWidth="500"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left">
                            <Expander
                                Margin="0,0,0,6"
                                Header="WEAPON STATS"
                                IsExpanded="True">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Damage:      85" />
                                    <TextBlock Text="Fire Rate:   6" />
                                    <TextBlock Text="Range:       119" />
                                    <TextBlock Text="Accuracy:    69" />
                                </StackPanel>
                            </Expander>
                            <Expander Margin="0,0,0,6" Header="ARMOR STATS">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Ballistic:   42" />
                                    <TextBlock Text="Energy:      38" />
                                    <TextBlock Text="Radiation:   15" />
                                </StackPanel>
                            </Expander>
                            <Expander Header="CLOSED EXPANDER (no expand)" />
                        </StackPanel>

                        <!--  Tab inside tab to show TabControl styling  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="TAB CONTROL (NESTED)" />
                        <TabControl
                            Height="140"
                            MaxWidth="500"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left">
                            <TabItem Header="STATUS">
                                <TextBlock Margin="8" Text="Character is in good health. No active status effects." />
                            </TabItem>
                            <TabItem Header="QUESTS">
                                <TextBlock Margin="8" Text="Active: The Nuclear Option" />
                            </TabItem>
                            <TabItem Header="MAP">
                                <TextBlock Margin="8" Text="Current location: The Glowing Sea" />
                            </TabItem>
                        </TabControl>

                        <!--  SplitView  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="SPLIT VIEW" />
                        <Border
                            Height="120"
                            MaxWidth="500"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left"
                            BorderBrush="{DynamicResource PipboyBorderBrush}"
                            BorderThickness="1">
                            <SplitView
                                DisplayMode="Inline"
                                IsPaneOpen="True"
                                OpenPaneLength="140">
                                <SplitView.Pane>
                                    <StackPanel Margin="8">
                                        <TextBlock Classes="dim" Text="NAVIGATION" />
                                        <TextBlock Margin="0,4,0,2" Text="STATUS" />
                                        <TextBlock Margin="0,2,0,2" Text="INVENTORY" />
                                        <TextBlock Margin="0,2,0,2" Text="MAP" />
                                    </StackPanel>
                                </SplitView.Pane>
                                <TextBlock
                                    Margin="12"
                                    Text="Main content area of the SplitView goes here."
                                    TextWrapping="Wrap" />
                            </SplitView>
                        </Border>

                        <!--  ToolTip demo  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="TOOLTIP" />
                        <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                            <Button Margin="0,0,8,0" Content="HOVER ME">
                                <ToolTip.Tip>
                                    <TextBlock Text="This is a Pipboy-styled tooltip.&#x0a;It can span multiple lines." />
                                </ToolTip.Tip>
                            </Button>
                            <TextBlock
                                VerticalAlignment="Center"
                                Classes="dim"
                                Text="(hover the button to see tooltip)" />
                        </StackPanel>

                        <!--  Date/Time pickers  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="DATE &amp; TIME PICKERS" />
                        <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                            <DatePicker Margin="0,0,12,0" />
                            <TimePicker Margin="0,0,12,0" />
                            <CalendarDatePicker Width="180" Watermark="Pick a date" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Tab 4: Window & Dialog =====  -->
            <TabItem Header="[ WINDOW ]">
                <StackPanel MaxWidth="600" Margin="12">
                    <TextBlock
                        Margin="0,0,0,8"
                        Classes="h1"
                        Text="WINDOW SHOWCASE" />
                    <TextBlock
                        Margin="0,0,0,16"
                        Text="The Pipboy theme applies globally to all Window instances including dialogs. Click below to open a styled dialog window and see the window chrome, title bar, and content styling in action."
                        TextWrapping="Wrap" />

                    <Border
                        Margin="0,0,0,16"
                        Padding="12"
                        Classes="pipboy-panel">
                        <StackPanel>
                            <TextBlock Classes="h2" Text="MAIN WINDOW PROPERTIES" />
                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Classes="dim"
                                    Text="Theme:" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Classes="accent"
                                    Text="Pipboy Green (default)" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Classes="dim"
                                    Text="Font:" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Text="Cascadia Code, Consolas, Monospace" />
                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    Classes="dim"
                                    Text="Platform:" />
                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Text="Avalonia UI 11.2.3" />
                                <TextBlock
                                    Grid.Row="6"
                                    Grid.Column="0"
                                    Classes="dim"
                                    Text="Mode:" />
                                <TextBlock
                                    Grid.Row="6"
                                    Grid.Column="1"
                                    Text="Runtime color switching enabled" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button
                        Margin="0,0,0,8"
                        Click="OnOpenDialog"
                        Content="OPEN DIALOG WINDOW" />
                    <TextBlock
                        Classes="dim"
                        Text="The dialog window will inherit the current Pipboy theme including any runtime color changes."
                        TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>

            <!--  ===== Tab 5: More Controls =====  -->
            <TabItem Header="[ MORE ]">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <!--  RepeatButton  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="REPEAT BUTTON" />
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="dim"
                            Text="Fires repeatedly while held down. Useful for increment/decrement controls."
                            TextWrapping="Wrap" />
                        <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                            <RepeatButton
                                Margin="0,0,8,0"
                                Content="◀ HOLD"
                                Delay="300"
                                Interval="100" />
                            <RepeatButton
                                Margin="0,0,8,0"
                                Content="▶ HOLD"
                                Delay="300"
                                Interval="100" />
                            <RepeatButton Content="DISABLED" IsEnabled="False" />
                        </StackPanel>

                        <!--  DropDownButton  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="DROP-DOWN BUTTON" />
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="dim"
                            Text="Button that opens a flyout menu when clicked."
                            TextWrapping="Wrap" />
                        <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                            <DropDownButton Margin="0,0,8,0" Content="SELECT FACTION">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Brotherhood of Steel" />
                                        <MenuItem Header="Railroad" />
                                        <MenuItem Header="Minutemen" />
                                        <MenuItem Header="Institute" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <DropDownButton Content="DISABLED" IsEnabled="False" />
                        </StackPanel>

                        <!--  HyperlinkButton  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="HYPERLINK BUTTON" />
                        <StackPanel Margin="0,0,0,16">
                            <HyperlinkButton
                                Margin="0,0,0,4"
                                Content="View Vault-Tec official site"
                                NavigateUri="https://www.fallout.com" />
                            <HyperlinkButton Margin="0,0,0,4" Content="Check SPECIAL stats" />
                            <HyperlinkButton Content="Disabled link" IsEnabled="False" />
                        </StackPanel>

                        <!--  DataValidationErrors  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="DATA VALIDATION" />
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="dim"
                            Text="TextBox controls show validation errors via DataValidationErrors. Bind with data annotations or INotifyDataErrorInfo."
                            TextWrapping="Wrap" />
                        <StackPanel
                            MaxWidth="400"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Left">
                            <TextBox Margin="0,0,0,6" Watermark="Enter target name (required)" />
                            <TextBox Margin="0,0,0,6" Watermark="Enter range (0-9999)" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Tab 6: Theme Switcher =====  -->
            <TabItem Header="[ THEME ]">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="500" Margin="12">
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="RUNTIME COLOR SWITCHING" />
                        <TextBlock
                            Margin="0,0,0,12"
                            Classes="dim"
                            Text="Change the primary color at runtime. All controls update instantly without restart."
                            TextWrapping="Wrap" />

                        <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                            <Button
                                Margin="0,0,6,6"
                                Click="OnColorButtonClick"
                                Content="PIPBOY GREEN"
                                Tag="#15FF52" />
                            <Button
                                Margin="0,0,6,6"
                                Click="OnColorButtonClick"
                                Content="AMBER"
                                Tag="#FFA500" />
                            <Button
                                Margin="0,0,6,6"
                                Click="OnColorButtonClick"
                                Content="BLUE"
                                Tag="#00BFFF" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <Button
                                Margin="0,0,6,6"
                                Click="OnColorButtonClick"
                                Content="RED"
                                Tag="#FF3030" />
                            <Button
                                Margin="0,0,6,6"
                                Click="OnColorButtonClick"
                                Content="CYAN"
                                Tag="#00FFEE" />
                            <Button
                                Margin="0,0,6,6"
                                Click="OnColorButtonClick"
                                Content="PURPLE"
                                Tag="#BB44FF" />
                        </StackPanel>

                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Text="HEX COLOR:" />
                            <TextBox
                                Name="HexColorBox"
                                Grid.Column="1"
                                Text="#15FF52"
                                Watermark="#15FF52" />
                            <Button
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                Click="OnApplyHexColor"
                                Content="APPLY" />
                        </Grid>

                        <TextBlock
                            Name="StatusText"
                            Margin="0,0,0,16"
                            Classes="dim"
                            Text="Current theme: Pipboy Green (#15FF52)" />

                        <!--  Live preview of all palette brushes  -->
                        <TextBlock
                            Margin="0,0,0,8"
                            Classes="h2"
                            Text="PALETTE PREVIEW" />
                        <ItemsControl Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <Border
                                Width="80"
                                Height="48"
                                Margin="0,0,4,4"
                                Background="{DynamicResource PipboyPrimaryBrush}">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    FontSize="10"
                                    Text="Primary" />
                            </Border>
                            <Border
                                Width="80"
                                Height="48"
                                Margin="0,0,4,4"
                                Background="{DynamicResource PipboyPrimaryLightBrush}">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    FontSize="10"
                                    Text="P.Light" />
                            </Border>
                            <Border
                                Width="80"
                                Height="48"
                                Margin="0,0,4,4"
                                Background="{DynamicResource PipboyPrimaryDarkBrush}">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    FontSize="10"
                                    Text="P.Dark" />
                            </Border>
                            <Border
                                Width="80"
                                Height="48"
                                Margin="0,0,4,4"
                                Background="{DynamicResource PipboyBackgroundBrush}"
                                BorderBrush="{DynamicResource PipboyBorderBrush}"
                                BorderThickness="1">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    FontSize="10"
                                    Text="Background" />
                            </Border>
                            <Border
                                Width="80"
                                Height="48"
                                Margin="0,0,4,4"
                                Background="{DynamicResource PipboySurfaceBrush}"
                                BorderBrush="{DynamicResource PipboyBorderBrush}"
                                BorderThickness="1">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    FontSize="10"
                                    Text="Surface" />
                            </Border>
                            <Border
                                Width="80"
                                Height="48"
                                Margin="0,0,4,4"
                                Background="{DynamicResource PipboySurfaceHighBrush}"
                                BorderBrush="{DynamicResource PipboyBorderBrush}"
                                BorderThickness="1">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    FontSize="10"
                                    Text="SurfHigh" />
                            </Border>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

    </Grid>

</Window>
