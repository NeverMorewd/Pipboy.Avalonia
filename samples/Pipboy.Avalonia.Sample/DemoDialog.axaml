<Window
    x:Class="Pipboy.Avalonia.Sample.DemoDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PIPBOY OS — DIALOG WINDOW"
    Width="560"
    Height="520"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="0" RowDefinitions="Auto,*,Auto">

        <!--  Title strip  -->
        <Border
            Grid.Row="0"
            Padding="16,10"
            Background="{DynamicResource PipboyPrimaryBrush}">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="16"
                Foreground="{DynamicResource PipboyBackgroundBrush}"
                Text="// VAULT-TEC TERMINAL v2.0 //" />
        </Border>

        <!--  Content  -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <TextBlock
                    Margin="0,0,0,12"
                    Classes="h2"
                    Text="SYSTEM DIAGNOSTIC REPORT" />

                <!--  Panel section  -->
                <Border
                    Margin="0,0,0,12"
                    Padding="12"
                    Classes="pipboy-panel">
                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Classes="dim"
                            Text="TERMINAL ID:" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Classes="accent"
                            Text="VLT-081-TRM-007" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Classes="dim"
                            Text="STATUS:" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Text="ONLINE" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Classes="dim"
                            Text="OPERATOR:" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Text="VAULT OVERSEER" />
                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="0"
                            Classes="dim"
                            Text="CLEARANCE:" />
                        <TextBlock
                            Grid.Row="6"
                            Grid.Column="1"
                            Classes="accent"
                            Text="LEVEL 5 — TOP SECRET" />
                    </Grid>
                </Border>

                <!--  Input fields  -->
                <TextBlock
                    Margin="0,0,0,8"
                    Classes="h2"
                    Text="AUTHENTICATION" />
                <TextBox Margin="0,0,0,6" Watermark="Enter access code..." />
                <TextBox
                    Margin="0,0,0,12"
                    PasswordChar="●"
                    Watermark="Password" />

                <!--  Options  -->
                <TextBlock
                    Margin="0,0,0,8"
                    Classes="h2"
                    Text="DIAGNOSTIC OPTIONS" />
                <StackPanel Margin="0,0,0,12">
                    <CheckBox
                        Margin="0,0,0,6"
                        Content="RUN MEMORY CHECK"
                        IsChecked="True" />
                    <CheckBox
                        Margin="0,0,0,6"
                        Content="SCAN NETWORK NODES"
                        IsChecked="True" />
                    <CheckBox
                        Margin="0,0,0,6"
                        Content="VERIFY VAULT DOOR SEALS"
                        IsChecked="False" />
                    <CheckBox Content="PURGE ERROR LOG" IsChecked="False" />
                </StackPanel>

                <!--  Priority selector  -->
                <TextBlock
                    Margin="0,0,0,8"
                    Classes="h2"
                    Text="PRIORITY LEVEL" />
                <ComboBox
                    Width="220"
                    Margin="0,0,0,12"
                    HorizontalAlignment="Left"
                    SelectedIndex="1">
                    <ComboBoxItem Content="CRITICAL — IMMEDIATE" />
                    <ComboBoxItem Content="HIGH — WITHIN 1 HOUR" />
                    <ComboBoxItem Content="NORMAL — SCHEDULED" />
                    <ComboBoxItem Content="LOW — DEFERRED" />
                </ComboBox>

                <!--  Progress  -->
                <TextBlock
                    Margin="0,0,0,8"
                    Classes="h2"
                    Text="LAST SCAN RESULTS" />
                <Grid
                    Margin="0,0,0,16"
                    ColumnDefinitions="140,*"
                    RowDefinitions="Auto,8,Auto,8,Auto">
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Classes="dim"
                        Text="MEMORY INTEGRITY:" />
                    <ProgressBar
                        Grid.Row="0"
                        Grid.Column="1"
                        Maximum="100"
                        Value="94" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Classes="dim"
                        Text="NETWORK NODES:" />
                    <ProgressBar
                        Grid.Row="2"
                        Grid.Column="1"
                        Maximum="100"
                        Value="77" />
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Classes="dim"
                        Text="VAULT SEALS:" />
                    <ProgressBar
                        Grid.Row="4"
                        Grid.Column="1"
                        Maximum="100"
                        Value="100" />
                </Grid>

                <!--  Log  -->
                <TextBlock
                    Margin="0,0,0,8"
                    Classes="h2"
                    Text="SYSTEM LOG" />
                <Border
                    Margin="0,0,0,8"
                    Padding="8"
                    Classes="pipboy-surface">
                    <StackPanel>
                        <TextBlock Classes="dim" Text="[2287-10-23 08:14:02] System boot complete" />
                        <TextBlock Classes="dim" Text="[2287-10-23 08:14:03] Network: 14/18 nodes online" />
                        <TextBlock Classes="dim" Text="[2287-10-23 08:14:05] Memory check: PASS (94%)" />
                        <TextBlock Classes="accent" Text="[2287-10-23 08:14:07] WARNING: Node 12 unreachable" />
                        <TextBlock Classes="dim" Text="[2287-10-23 08:14:09] Vault door seal: INTACT" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!--  Footer buttons  -->
        <Border
            Grid.Row="2"
            Padding="16,10"
            BorderBrush="{DynamicResource PipboyBorderBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Click="OnRunDiagnostic"
                    Content="RUN DIAGNOSTIC" />
                <Button Click="OnClose" Content="CLOSE" />
            </StackPanel>
        </Border>

    </Grid>

</Window>
